# App
PORT=3000
HOST=0.0.0.0

# Database
# In Docker Compose, DB_HOST should be the mysql service name.
DB_HOST=mysql
DB_USER=campusquest
DB_PASSWORD=campusquest_password
DB_NAME=campusquest
MYSQL_ROOT_PASSWORD=campusquest_root_password
DB_CONNECT_RETRIES=30
DB_CONNECT_RETRY_DELAY_MS=2000

# Session
SESSION_SECRET=change_me_for_local_development
